@page "/configuration/{Entity}"
@using HunterIndustriesAPIControlPanel.Models.Responses.Related

<PageTitle>@DisplayName Configuration</PageTitle>

<div class="mb-3">
    <a href="/configuration" class="btn btn-outline-light btn-sm">&larr; Back to Configuration</a>
</div>

<div class="page-header">
    <h1>@DisplayName Configuration</h1>
</div>

@if (Records == null)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">@DisplayName Configuration</h4>
        <button class="btn btn-primary" @onclick="StartAdd">Add @DisplayName</button>
    </div>

    @if (IsAdding)
    {
        <div class="card mb-4 card-highlighted">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">New @DisplayName</h5>
            </div>
            <div class="card-body">
                @switch (Entity)
                {
                    case "application":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="NewAppName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phrase</label>
                                <select class="form-control" @bind="NewAppPhrase">
                                    <option value="" disabled selected>Select an option</option>
                                    @foreach (string phrase in Phrases)
                                    {
                                        <option value="@phrase">@phrase</option>
                                    }
                                </select>
                            </div>
                        </div>
                        break;
                    case "authorisation":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Phrase</label>
                                <input type="text" class="form-control" @bind="NewAuthPhrase" />
                            </div>
                        </div>
                        break;
                    case "component":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="NewComponentName" />
                            </div>
                        </div>
                        break;
                    case "connection":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">IP Address</label>
                                <input type="text" class="form-control" @bind="NewConnectionIP" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Port</label>
                                <input type="number" class="form-control" @bind="NewConnectionPort" />
                            </div>
                        </div>
                        break;
                    case "downtime":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Time</label>
                                <input type="text" class="form-control" @bind="NewDowntimeTime" placeholder="HH:mm:ss" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Duration (seconds)</label>
                                <input type="number" class="form-control" @bind="NewDowntimeDuration" />
                            </div>
                        </div>
                        break;
                    case "game":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="NewGameName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Version</label>
                                <input type="text" class="form-control" @bind="NewGameVersion" />
                            </div>
                        </div>
                        break;
                    case "machine":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Host Name</label>
                                <input type="text" class="form-control" @bind="NewMachineHostName" />
                            </div>
                        </div>
                        break;
                }
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary" disabled="@IsLoading" @onclick="ConfirmAdd">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        Create
                    </button>
                    <button class="btn btn-outline-light ms-2" @onclick="CancelAdd">Cancel</button>
                </div>
            </div>
        </div>
    }

    <!-- Results -->
    <RadzenDataGrid Data="@Records?.Entries"
        TItem="ConfigurationListObjectModel"
        AllowSorting="false"
        RowClick="@(args => Navigation.NavigateTo($"/configuration/{Entity}/{args.Data.Id}?fromPage={PageNumber}"))"
        Style="cursor: pointer;">
        <Columns>
            <RadzenDataGridColumn TItem="ConfigurationListObjectModel"
                Property="Id"
                Title="ID" />
            <RadzenDataGridColumn TItem="ConfigurationListObjectModel"
                Property="Name"
                Title="Value" />
            <RadzenDataGridColumn TItem="ConfigurationListObjectModel"
                Title="Status">
                <Template Context="configurationObject">
                    @if (configurationObject.IsDeleted)
                    {
                        <StatusBadge Text="Deleted"
                            Type="deleted" />
                    }

                    else
                    {
                        <StatusBadge Text="Active"
                            Type="active" />
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-muted">
            Showing @((Records?.PageNumber - 1) * Records?.PageSize + 1)-@((Records?.PageNumber - 1) * Records?.PageSize + Records?.EntryCount)
            of @Records?.TotalCount records
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm page-size-select" @bind="PageSize" @bind:after="ApplyFilters">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            <button class="btn btn-outline-light btn-sm" disabled="@(PageNumber <= 1)" @onclick="PreviousPage">&laquo; Prev</button>
            <span class="text-muted">Page @PageNumber of @Records?.TotalPageCount</span>
            <button class="btn btn-outline-light btn-sm" disabled="@(PageNumber >= Records?.TotalPageCount)" @onclick="NextPage">Next &raquo;</button>
        </div>
    </div>
}
