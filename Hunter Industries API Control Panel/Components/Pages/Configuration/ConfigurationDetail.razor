@page "/configuration/{Entity}/{Id:int}"

<PageTitle>@DisplayName Configuration Detail</PageTitle>

<div class="mb-3">
    <a href="/configuration/@Entity" class="btn btn-outline-light btn-sm">&larr; Back to @DisplayName Configuration</a>
</div>

@if (IsLoading && !HasData)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

else
{
    @if (!HasData)
    {
        <div class="alert alert-warning">@DisplayName not found.</div>
    }

    else
    {
        @switch (Entity)
        {
            case "application":
                <div class="card mb-4 card-rounded">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">@Application?.Name</h5>
                        @if (IsDeleted)
                        {
                            <StatusBadge
                                Text="Deleted"
                                Type="deleted" />
                        }
                        else
                        {
                            <StatusBadge
                                Text="Active"
                                Type="active" />
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="EditAppName" disabled="@IsDeleted" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phrase</label>
                                <select class="form-control" @bind="EditAppPhrase" disabled="@IsDeleted">
                                    <option value="@Application?.Authorisation.Phrase" disabled selected>@Application?.Authorisation.Phrase</option>
                                    @foreach (string phrase in Phrases)
                                    {
                                        <option value="@phrase">@phrase</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @if (!IsDeleted)
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSaving" @onclick="SaveApplication">
                                        @if (IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Save Changes
                                    </button>
                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "Entity")
                                    {
                                        <div class="alert alert-danger py-2 d-inline-block ms-2 mb-0 align-middle">@ErrorMessage</div>
                                    }

                                    @if (SaveSuccess)
                                    {
                                        <span class="text-success ms-2">Saved changes successfully!</span>
                                    }
                                </div>
                                @if (!IsControlPanelApplication)
                                {
                                    <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete()">Delete Application</button>
                                }
                            </div>
                        }

                        <!-- Application Settings -->
                        <hr class="mt-4 divider" />
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0">Settings</h6>
                            @if (!IsDeleted)
                            {
                                <button class="btn btn-outline-light btn-sm" @onclick="StartAddSetting">Add Setting</button>
                            }
                        </div>

                        @if (NewSetting != null)
                        {
                            <div class="card mb-3 card-highlighted">
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label class="form-label">Name</label>
                                            <input type="text" class="form-control" @bind="NewSetting.Name" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Type</label>
                                            <select class="form-control" @bind="NewSetting.Type">
                                                <option value="" disabled selected>Select an option</option>
                                                @foreach (KeyValuePair<string, string> dataType in DataTypes.OrderBy(dt => dt.Value))
                                                {
                                                    <option value="@dataType.Key">@dataType.Value</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label text-center">Required</label>
                                            <div class="form-check mt-2 d-flex vertical-align-center">
                                                <input class="form-check-input" type="checkbox" @bind="NewSetting.Required" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <button class="btn btn-outline-light btn-sm ms-2" @onclick="CancelAddSetting">Cancel</button>
                                        <button type="submit" class="btn btn-primary btn-sm" disabled="@IsAddingSetting" @onclick="ConfirmAddSetting">
                                            @if (IsAddingSetting)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                            }
                                            Save
                                        </button>
                                        @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "AddSetting")
                                        {
                                            <div class="alert alert-danger py-2">@ErrorMessage</div>
                                        }

                                        @if (AddSettingSuccess)
                                        {
                                            <div class="text-success ms-2">Created setting successfully!</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @if (Application?.Settings.Count > 0)
                        {
                            <div class="table-scroll-wrapper">
                            <table class="table table-sm">
                                <colgroup>
                                    <col class="col-name" />
                                    <col class="col-type" />
                                    <col class="col-required" />
                                    <col class="col-status" />
                                    <col class="col-actions" />
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th class="text-center">Required</th>
                                        <th>Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (ApplicationSettingModel setting in Application.Settings)
                                    {
                                        <tr>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" @bind="setting.Name" disabled="@(IsDeleted || setting.IsDeleted)" />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" @bind="setting.Type" disabled="@(IsDeleted || setting.IsDeleted)" />
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check d-flex justify-content-center">
                                                    <input class="form-check-input" type="checkbox" @bind="setting.Required" disabled="@(IsDeleted || setting.IsDeleted)" />
                                                </div>
                                            </td>
                                            <td>
                                                @if (setting.IsDeleted)
                                                {
                                                    <StatusBadge
                                                        Text="Deleted"
                                                        Type="deleted" />
                                                }

                                                else
                                                {
                                                    <StatusBadge
                                                        Text="Active"
                                                        Type="active" />
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (!IsDeleted && !setting.IsDeleted)
                                                {
                                                    <button type="submit" class="btn btn-primary btn-sm me-1" disabled="@IsSavingSetting" @onclick="() => SaveSetting(setting)">
                                                        @if (IsSavingSetting && EditSettingId == setting.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                        }
                                                        Save
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(setting.Id)">Delete</button>
                                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == $"SaveSetting {setting.Id}")
                                                    {
                                                        <div class="alert alert-danger py-2">@ErrorMessage</div>
                                                    }

                                                    @if (SaveSettingSuccess && EditSettingId == setting.Id)
                                                    {
                                                        <div class="text-success ms-2">Updated setting successfully!</div>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            </div>
                        }

                        else
                        {
                            <p class="text-muted">No settings configured.</p>
                        }
                    </div>
                </div>
                break;

            case "authorisation":
                <div class="card mb-3 card-rounded">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">Authorisation #@Authorisation?.Id</h6>
                        @if (IsDeleted)
                        {
                            <StatusBadge
                                Text="Deleted"
                                Type="deleted" />
                        }
                        else
                        {
                            <StatusBadge
                                Text="Active"
                                Type="active" />
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Phrase</label>
                                <input type="text" class="form-control" @bind="EditAuthPhrase" disabled="@IsDeleted" />
                            </div>
                        </div>
                        @if (!IsDeleted)
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSaving" @onclick="SaveAuthorisation">
                                        @if (IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Save Changes
                                    </button>
                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "Entity")
                                    {
                                        <div class="alert alert-danger py-2 d-inline-block ms-2 mb-0 align-middle">@ErrorMessage</div>
                                    }

                                    @if (SaveSuccess)
                                    {
                                        <span class="text-success ms-2">Saved changes successfully!</span>
                                    }
                                </div>
                                @if (!IsControlPanelAuthorisation)
                                {
                                    <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete()">Delete</button>
                                }
                            </div>
                        }
                    </div>
                </div>
                break;

            case "component":
                <div class="card mb-3 card-rounded">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">@Component?.Name</h6>
                        @if (IsDeleted)
                        {
                            <StatusBadge
                                Text="Deleted"
                                Type="deleted" />
                        }
                        else
                        {
                            <StatusBadge
                                Text="Active"
                                Type="active" />
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="EditComponentName" disabled="@IsDeleted" />
                            </div>
                        </div>
                        @if (!IsDeleted)
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSaving" @onclick="SaveComponent">
                                        @if (IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Save Changes
                                    </button>
                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "Entity")
                                    {
                                        <div class="alert alert-danger py-2 d-inline-block ms-2 mb-0 align-middle">@ErrorMessage</div>
                                    }

                                    @if (SaveSuccess)
                                    {
                                        <span class="text-success ms-2">Saved changes successfully!</span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete()">Delete</button>
                            </div>
                        }
                    </div>
                </div>
                break;

            case "connection":
                <div class="card mb-3 card-rounded">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">@Connection?.IPAddress:@Connection?.Port</h6>
                        @if (IsDeleted)
                        {
                            <StatusBadge
                                Text="Deleted"
                                Type="deleted" />
                        }
                        else
                        {
                            <StatusBadge
                                Text="Active"
                                Type="active" />
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">IP Address</label>
                                <input type="text" class="form-control" @bind="EditConnectionIP" disabled="@IsDeleted" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Port</label>
                                <input type="number" class="form-control" @bind="EditConnectionPort" disabled="@IsDeleted" />
                            </div>
                        </div>
                        @if (!IsDeleted)
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSaving" @onclick="SaveConnection">
                                        @if (IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Save Changes
                                    </button>
                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "Entity")
                                    {
                                        <div class="alert alert-danger py-2 d-inline-block ms-2 mb-0 align-middle">@ErrorMessage</div>
                                    }

                                    @if (SaveSuccess)
                                    {
                                        <span class="text-success ms-2">Saved changes successfully!</span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete()">Delete</button>
                            </div>
                        }
                    </div>
                </div>
                break;

            case "downtime":
                <div class="card mb-3 card-rounded">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">@Downtime?.Time (@Downtime?.Duration)</h6>
                        @if (IsDeleted)
                        {
                            <StatusBadge
                                Text="Deleted"
                                Type="deleted" />
                        }
                        else
                        {
                            <StatusBadge
                                Text="Active"
                                Type="active" />
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Time</label>
                                <input type="text" class="form-control" @bind="EditDowntimeTime" disabled="@IsDeleted" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Duration (seconds)</label>
                                <input type="number" class="form-control" @bind="EditDowntimeDuration" disabled="@IsDeleted" />
                            </div>
                        </div>
                        @if (!IsDeleted)
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSaving" @onclick="SaveDowntime">
                                        @if (IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Save Changes
                                    </button>
                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "Entity")
                                    {
                                        <div class="alert alert-danger py-2 d-inline-block ms-2 mb-0 align-middle">@ErrorMessage</div>
                                    }

                                    @if (SaveSuccess)
                                    {
                                        <span class="text-success ms-2">Saved changes successfully!</span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete()">Delete</button>
                            </div>
                        }
                    </div>
                </div>
                break;

            case "game":
                <div class="card mb-3 card-rounded">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">@Game?.Name (@Game?.Version)</h6>
                        @if (IsDeleted)
                        {
                            <StatusBadge
                                Text="Deleted"
                                Type="deleted" />
                        }
                        else
                        {
                            <StatusBadge
                                Text="Active"
                                Type="active" />
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="EditGameName" disabled="@IsDeleted" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Version</label>
                                <input type="text" class="form-control" @bind="EditGameVersion" disabled="@IsDeleted" />
                            </div>
                        </div>
                        @if (!IsDeleted)
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSaving" @onclick="SaveGame">
                                        @if (IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Save Changes
                                    </button>
                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "Entity")
                                    {
                                        <div class="alert alert-danger py-2 d-inline-block ms-2 mb-0 align-middle">@ErrorMessage</div>
                                    }

                                    @if (SaveSuccess)
                                    {
                                        <span class="text-success ms-2">Saved changes successfully!</span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete()">Delete</button>
                            </div>
                        }
                    </div>
                </div>
                break;

            case "machine":
                <div class="card mb-3 card-rounded">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">@Machine?.HostName</h6>
                        @if (IsDeleted)
                        {
                            <StatusBadge
                                Text="Deleted"
                                Type="deleted" />
                        }
                        else
                        {
                            <StatusBadge
                                Text="Active"
                                Type="active" />
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Host Name</label>
                                <input type="text" class="form-control" @bind="EditHostName" disabled="@IsDeleted" />
                            </div>
                        </div>
                        @if (!IsDeleted)
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSaving" @onclick="SaveMachine">
                                        @if (IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Save Changes
                                    </button>
                                    @if (!string.IsNullOrEmpty(ErrorMessage) && ErrorFor == "Entity")
                                    {
                                        <div class="alert alert-danger py-2 d-inline-block ms-2 mb-0 align-middle">@ErrorMessage</div>
                                    }

                                    @if (SaveSuccess)
                                    {
                                        <span class="text-success ms-2">Saved changes successfully!</span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete()">Delete</button>
                            </div>
                        }
                    </div>
                </div>
                break;

            default:
                <div class="alert alert-warning">Unknown configuration type: @Entity</div>
                break;
        }
    }
}

<ConfirmDialog
    IsVisible="ShowDeleteConfirm"
    Title="@($"Delete {DeleteDisplayName}")"
    Message="@($"Are you sure you want to delete this {DeleteDisplayName.ToLower()} record?")"
    ConfirmText="Delete"
    OnConfirm="DeleteConfiguration"
    OnCancel="CancelDelete" />
