@page "/configuration"

<PageTitle>Configuration - HI Control Panel</PageTitle>

<h4 class="mb-4">Configuration</h4>

<div class="row g-4">
    @foreach (var configType in ConfigTypes)
    {
        <div class="col-md-4 col-xl-3">
            <a href="/configuration/@configType.Key" class="text-decoration-none">
                <div class="card h-100 config-card">
                    <div class="card-body text-center py-4">
                        <div class="mb-3 config-icon">
                            @((MarkupString)configType.Value.Icon)
                        </div>
                        <h5 class="card-title mb-0 config-title">@configType.Value.DisplayName</h5>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
