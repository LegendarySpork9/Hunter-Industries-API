@page "/users/{Id:int}"

<PageTitle>User Detail - HI Control Panel</PageTitle>

<div class="mb-3">
    <a href="/users" class="btn btn-outline-light btn-sm">&larr; Back to Users</a>
</div>

@if (_user == null)
{
    <div class="alert alert-warning">User not found.</div>
}
else
{
    <!-- User Information -->
    <div class="card mb-4" style="border-radius: 8px;">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">User Information</h5>
            @if (_user.IsDeleted)
            {
                <StatusBadge Text="Deleted" Type="deleted" />
            }
            else
            {
                <StatusBadge Text="Active" Type="active" />
            }
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Username</label>
                    <input type="text" class="form-control" @bind="_editUsername" disabled="@_user.IsDeleted" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <input type="@(_showPassword ? "text" : "password")" class="form-control" @bind="_editPassword" disabled="@_user.IsDeleted" />
                        <button class="btn btn-outline-light" type="button" @onclick="() => _showPassword = !_showPassword">
                            @(_showPassword ? "Hide" : "Show")
                        </button>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <label class="form-label">Scopes</label>
                <div class="row">
                    @foreach (var scope in _availableScopes)
                    {
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@_editScopes.Contains(scope)"
                                       @onchange="(e) => ToggleScope(scope, (bool)e.Value!)" disabled="@_user.IsDeleted" />
                                <label class="form-check-label">@scope</label>
                            </div>
                        </div>
                    }
                </div>
            </div>
            @if (!_user.IsDeleted)
            {
                <div class="mt-3 d-flex justify-content-between">
                    <div>
                        <button class="btn btn-primary" @onclick="SaveUser">Save Changes</button>
                        @if (_saveSuccess)
                        {
                            <span class="text-success ms-2">Saved successfully!</span>
                        }
                    </div>
                    <button class="btn btn-outline-danger" @onclick="ConfirmDelete">Delete User</button>
                </div>
            }
        </div>
    </div>

    <!-- Application Settings -->
    <h5 class="mb-3">Application Settings</h5>
    @foreach (var app in _allAppSettings)
    {
        var userApp = _userSettings.FirstOrDefault(s => s.Application == app.Application);
        <div class="card mb-3" style="border-radius: 8px;">
            <div class="card-header">
                <h6 class="mb-0">@app.Application</h6>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-2" style="table-layout: fixed;">
                    <colgroup>
                        <col style="width: 40%;" />
                        <col style="width: 60%;" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Setting</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var setting in app.Settings)
                        {
                            var userSetting = userApp?.Settings.FirstOrDefault(s => s.Name == setting.Name);
                            <tr>
                                <td style="color: #D7D7D7;">@setting.Name</td>
                                <td>
                                    @if (userSetting != null)
                                    {
                                        <input type="text" class="form-control form-control-sm" style="max-width: 300px;"
                                               @bind="userSetting.Value" disabled="@_user.IsDeleted" />
                                    }
                                    else if (!_user.IsDeleted && IsAddingSetting(app.Application, setting.Name))
                                    {
                                        <div class="d-flex gap-2 align-items-center" style="max-width: 300px;">
                                            <input type="text" class="form-control form-control-sm"
                                                   value="@GetNewSettingValue(app.Application, setting.Name)"
                                                   @onchange="(e) => SetNewSettingValue(app.Application, setting.Name, e.Value?.ToString() ?? string.Empty)"
                                                   placeholder="Enter value..." />
                                            <button class="btn btn-primary btn-sm" @onclick="() => ConfirmAddSetting(app.Application, setting.Name)">Save</button>
                                            <button class="btn btn-outline-light btn-sm" @onclick="() => CancelAddSetting(app.Application, setting.Name)">Cancel</button>
                                        </div>
                                    }
                                    else if (!_user.IsDeleted)
                                    {
                                        <button class="btn btn-outline-light btn-sm" @onclick="() => StartAddSetting(app.Application, setting.Name)">Add</button>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (userApp != null && userApp.Settings.Count > 0 && !_user.IsDeleted)
                {
                    <button class="btn btn-primary btn-sm" @onclick="() => SaveSettings(userApp)">Save Settings</button>
                }
            </div>
        </div>
    }
}

<ConfirmDialog IsVisible="_showDeleteConfirm" Title="Delete User"
               Message="@($"Are you sure you want to delete user '{_user?.Username}'?")"
               ConfirmText="Delete" OnConfirm="DeleteUser" OnCancel="CancelDelete" />
