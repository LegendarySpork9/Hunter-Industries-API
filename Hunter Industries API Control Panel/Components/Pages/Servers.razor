@page "/servers"

<PageTitle>Servers - HI Control Panel</PageTitle>

<div class="page-header">
    <h1>Servers</h1>
    <button class="btn btn-primary" @onclick="ShowCreateModal">Add Server</button>
</div>

<RadzenDataGrid Data="@_servers" TItem="ServerInformationRecord" AllowSorting="true" AllowFiltering="true"
                FilterMode="FilterMode.Simple" PageSize="25" AllowPaging="true"
                RowClick="@(args => Navigation.NavigateTo($"/servers/{args.Data.Id}"))"
                Style="cursor: pointer;">
    <Columns>
        <RadzenDataGridColumn TItem="ServerInformationRecord" Property="Id" Title="ID" Width="70px" />
        <RadzenDataGridColumn TItem="ServerInformationRecord" Property="HostName" Title="Host Name" />
        <RadzenDataGridColumn TItem="ServerInformationRecord" Property="Game" Title="Game" />
        <RadzenDataGridColumn TItem="ServerInformationRecord" Property="GameVersion" Title="Version" Width="100px" />
        <RadzenDataGridColumn TItem="ServerInformationRecord" Title="Address" Sortable="false" Filterable="false">
            <Template Context="server">
                @server.Connection.IPAddress:@server.Connection.Port
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ServerInformationRecord" Title="Downtime" Width="100px" Sortable="false" Filterable="false">
            <Template Context="server">
                @(server.Downtime?.Time ?? "N/A")
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ServerInformationRecord" Title="Status" Width="100px" Sortable="false" Filterable="false">
            <Template Context="server">
                @if (server.IsActive)
                {
                    <StatusBadge Text="Active" Type="active" />
                }
                else
                {
                    <StatusBadge Text="Inactive" Type="inactive" />
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ServerInformationRecord" Title="Actions" Width="80px" Sortable="false" Filterable="false">
            <Template Context="server">
                <button class="btn btn-sm btn-outline-light" @onclick="() => ShowEditModal(server)" @onclick:stopPropagation="true" title="Edit">
                    &#9998;
                </button>
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

<!-- Create/Edit Server Modal -->
@if (_showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEditing ? "Edit Server" : "Add Server")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Host Name</label>
                        <input type="text" class="form-control" @bind="_modalHostName" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Game</label>
                            <input type="text" class="form-control" @bind="_modalGame" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Game Version</label>
                            <input type="text" class="form-control" @bind="_modalGameVersion" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" @bind="_modalIPAddress" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Port</label>
                            <input type="number" class="form-control" @bind="_modalPort" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Downtime (HH:MM:SS)</label>
                            <input type="text" class="form-control" @bind="_modalDowntime" placeholder="03:00:00" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="_modalIsActive" />
                                <label class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light btn-sm" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="SaveServer">
                        @(_isEditing ? "Save Changes" : "Create")
                    </button>
                </div>
            </div>
        </div>
    </div>
}
