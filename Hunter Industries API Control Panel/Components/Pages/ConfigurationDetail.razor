@page "/configuration/{Entity}"

<PageTitle>@_displayName Configuration - HI Control Panel</PageTitle>

<div class="mb-3">
    <a href="/configuration" class="btn btn-outline-light btn-sm">&larr; Back to Configuration</a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">@_displayName Configuration</h4>
    <button class="btn btn-primary" @onclick="StartAdd">Add @_displayName</button>
</div>

@if (_isAdding)
{
    <div class="card mb-4" style="border-radius: 8px; border: 1px solid #7ec8e3;">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">New @_displayName</h5>
        </div>
        <div class="card-body">
            @switch (Entity)
            {
                case "application":
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="_newAppName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phrase</label>
                            <input type="text" class="form-control" @bind="_newAppPhrase" />
                        </div>
                    </div>
                    break;
                case "authorisation":
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Phrase</label>
                            <input type="text" class="form-control" @bind="_newAuthPhrase" />
                        </div>
                    </div>
                    break;
                case "component":
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="_newComponentName" />
                        </div>
                    </div>
                    break;
                case "connection":
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" @bind="_newConnectionIP" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Port</label>
                            <input type="number" class="form-control" @bind="_newConnectionPort" />
                        </div>
                    </div>
                    break;
                case "downtime":
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Time</label>
                            <input type="text" class="form-control" @bind="_newDowntimeTime" placeholder="HH:mm:ss" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Duration (seconds)</label>
                            <input type="number" class="form-control" @bind="_newDowntimeDuration" />
                        </div>
                    </div>
                    break;
                case "game":
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="_newGameName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Version</label>
                            <input type="text" class="form-control" @bind="_newGameVersion" />
                        </div>
                    </div>
                    break;
                case "machine":
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Host Name</label>
                            <input type="text" class="form-control" @bind="_newMachineHostName" />
                        </div>
                    </div>
                    break;
            }
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="ConfirmAdd">Save</button>
                <button class="btn btn-outline-light ms-2" @onclick="CancelAdd">Cancel</button>
            </div>
        </div>
    </div>
}

@switch (Entity)
{
    case "application":
        @foreach (var app in _applications)
        {
            <div class="card mb-4" style="border-radius: 8px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@app.Name</h5>
                    @if (app.IsDeleted)
                    {
                        <StatusBadge Text="Deleted" Type="deleted" />
                    }
                    else
                    {
                        <StatusBadge Text="Active" Type="active" />
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="app.Name" disabled="@app.IsDeleted" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phrase</label>
                            <input type="text" class="form-control" @bind="app.Phrase" disabled="@app.IsDeleted" />
                        </div>
                    </div>

                    @if (!app.IsDeleted)
                    {
                        <div class="mt-3 d-flex justify-content-between">
                            <div>
                                <button class="btn btn-primary" @onclick="() => SaveApplication(app)">Save Changes</button>
                                <button class="btn btn-outline-light ms-2" @onclick="() => NavigateToLogs(app.Id)" title="Logs">&#128203; Logs</button>
                                @if (_saveSuccessId == app.Id)
                                {
                                    <span class="text-success ms-2">Saved successfully!</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(app.Id)">Delete</button>
                        </div>
                    }

                    <!-- Application Settings -->
                    <hr class="mt-4" style="border-color: #555;" />
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">Settings</h6>
                        @if (!app.IsDeleted)
                        {
                            <button class="btn btn-outline-light btn-sm" @onclick="() => StartAddSetting(app.Id)">Add Setting</button>
                        }
                    </div>

                    @if (_isAddingSettingForAppId == app.Id)
                    {
                        <div class="card mb-3" style="border-radius: 8px; border: 1px solid #7ec8e3;">
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label">Name</label>
                                        <input type="text" class="form-control" @bind="_newSettingName" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Type</label>
                                        <input type="text" class="form-control" @bind="_newSettingType" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Required</label>
                                        <div class="form-check mt-2">
                                            <input class="form-check-input" type="checkbox" @bind="_newSettingRequired" />
                                            <label class="form-check-label">Yes</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <button class="btn btn-primary btn-sm" @onclick="() => ConfirmAddSetting(app.Id)">Save</button>
                                    <button class="btn btn-outline-light btn-sm ms-2" @onclick="CancelAddSetting">Cancel</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (app.Settings.Count > 0)
                    {
                        <table class="table table-sm" style="table-layout: fixed;">
                            <colgroup>
                                <col style="width: 30%;" />
                                <col style="width: 30%;" />
                                <col style="width: 15%;" />
                                <col style="width: 10%;" />
                                <col style="width: 15%;" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Required</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var setting in app.Settings)
                                {
                                    <tr>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" @bind="setting.Name" disabled="@(app.IsDeleted || setting.IsDeleted)" />
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" @bind="setting.Type" disabled="@(app.IsDeleted || setting.IsDeleted)" />
                                        </td>
                                        <td>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" @bind="setting.Required" disabled="@(app.IsDeleted || setting.IsDeleted)" />
                                            </div>
                                        </td>
                                        <td>
                                            @if (setting.IsDeleted)
                                            {
                                                <StatusBadge Text="Deleted" Type="deleted" />
                                            }
                                            else
                                            {
                                                <StatusBadge Text="Active" Type="active" />
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (!app.IsDeleted && !setting.IsDeleted)
                                            {
                                                <button class="btn btn-primary btn-sm me-1" @onclick="() => SaveSetting(app.Id, setting)">Save</button>
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteSetting(app.Id, setting.Id)">Delete</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No settings configured.</p>
                    }
                </div>
            </div>
        }
        break;

    case "authorisation":
        @foreach (var auth in _authorisations)
        {
            <div class="card mb-3" style="border-radius: 8px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Authorisation #@auth.Id</h6>
                    @if (auth.IsDeleted)
                    {
                        <StatusBadge Text="Deleted" Type="deleted" />
                    }
                    else
                    {
                        <StatusBadge Text="Active" Type="active" />
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Phrase</label>
                            <input type="text" class="form-control" @bind="auth.Phrase" disabled="@auth.IsDeleted" />
                        </div>
                    </div>
                    @if (!auth.IsDeleted)
                    {
                        <div class="mt-3 d-flex justify-content-between">
                            <div>
                                <button class="btn btn-primary" @onclick="() => SaveAuthorisation(auth)">Save Changes</button>
                                @if (_saveSuccessId == auth.Id)
                                {
                                    <span class="text-success ms-2">Saved successfully!</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(auth.Id)">Delete</button>
                        </div>
                    }
                </div>
            </div>
        }
        break;

    case "component":
        @foreach (var comp in _components)
        {
            <div class="card mb-3" style="border-radius: 8px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">@comp.Name</h6>
                    @if (comp.IsDeleted)
                    {
                        <StatusBadge Text="Deleted" Type="deleted" />
                    }
                    else
                    {
                        <StatusBadge Text="Active" Type="active" />
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="comp.Name" disabled="@comp.IsDeleted" />
                        </div>
                    </div>
                    @if (!comp.IsDeleted)
                    {
                        <div class="mt-3 d-flex justify-content-between">
                            <div>
                                <button class="btn btn-primary" @onclick="() => SaveComponent(comp)">Save Changes</button>
                                @if (_saveSuccessId == comp.Id)
                                {
                                    <span class="text-success ms-2">Saved successfully!</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(comp.Id)">Delete</button>
                        </div>
                    }
                </div>
            </div>
        }
        break;

    case "connection":
        @foreach (var conn in _connections)
        {
            <div class="card mb-3" style="border-radius: 8px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">@conn.IPAddress:@conn.Port</h6>
                    @if (conn.IsDeleted)
                    {
                        <StatusBadge Text="Deleted" Type="deleted" />
                    }
                    else
                    {
                        <StatusBadge Text="Active" Type="active" />
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" @bind="conn.IPAddress" disabled="@conn.IsDeleted" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Port</label>
                            <input type="number" class="form-control" @bind="conn.Port" disabled="@conn.IsDeleted" />
                        </div>
                    </div>
                    @if (!conn.IsDeleted)
                    {
                        <div class="mt-3 d-flex justify-content-between">
                            <div>
                                <button class="btn btn-primary" @onclick="() => SaveConnection(conn)">Save Changes</button>
                                @if (_saveSuccessId == conn.Id)
                                {
                                    <span class="text-success ms-2">Saved successfully!</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(conn.Id)">Delete</button>
                        </div>
                    }
                </div>
            </div>
        }
        break;

    case "downtime":
        @foreach (var dt in _downtimes)
        {
            <div class="card mb-3" style="border-radius: 8px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">@dt.Time</h6>
                    @if (dt.IsDeleted)
                    {
                        <StatusBadge Text="Deleted" Type="deleted" />
                    }
                    else
                    {
                        <StatusBadge Text="Active" Type="active" />
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Time</label>
                            <input type="text" class="form-control" @bind="dt.Time" disabled="@dt.IsDeleted" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Duration (seconds)</label>
                            <input type="number" class="form-control" @bind="dt.Duration" disabled="@dt.IsDeleted" />
                        </div>
                    </div>
                    @if (!dt.IsDeleted)
                    {
                        <div class="mt-3 d-flex justify-content-between">
                            <div>
                                <button class="btn btn-primary" @onclick="() => SaveDowntime(dt)">Save Changes</button>
                                @if (_saveSuccessId == dt.Id)
                                {
                                    <span class="text-success ms-2">Saved successfully!</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(dt.Id)">Delete</button>
                        </div>
                    }
                </div>
            </div>
        }
        break;

    case "game":
        @foreach (var game in _games)
        {
            <div class="card mb-3" style="border-radius: 8px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">@game.Name @game.Version</h6>
                    @if (game.IsDeleted)
                    {
                        <StatusBadge Text="Deleted" Type="deleted" />
                    }
                    else
                    {
                        <StatusBadge Text="Active" Type="active" />
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="game.Name" disabled="@game.IsDeleted" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Version</label>
                            <input type="text" class="form-control" @bind="game.Version" disabled="@game.IsDeleted" />
                        </div>
                    </div>
                    @if (!game.IsDeleted)
                    {
                        <div class="mt-3 d-flex justify-content-between">
                            <div>
                                <button class="btn btn-primary" @onclick="() => SaveGame(game)">Save Changes</button>
                                @if (_saveSuccessId == game.Id)
                                {
                                    <span class="text-success ms-2">Saved successfully!</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(game.Id)">Delete</button>
                        </div>
                    }
                </div>
            </div>
        }
        break;

    case "machine":
        @foreach (var machine in _machines)
        {
            <div class="card mb-3" style="border-radius: 8px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">@machine.HostName</h6>
                    @if (machine.IsDeleted)
                    {
                        <StatusBadge Text="Deleted" Type="deleted" />
                    }
                    else
                    {
                        <StatusBadge Text="Active" Type="active" />
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Host Name</label>
                            <input type="text" class="form-control" @bind="machine.HostName" disabled="@machine.IsDeleted" />
                        </div>
                    </div>
                    @if (!machine.IsDeleted)
                    {
                        <div class="mt-3 d-flex justify-content-between">
                            <div>
                                <button class="btn btn-primary" @onclick="() => SaveMachine(machine)">Save Changes</button>
                                @if (_saveSuccessId == machine.Id)
                                {
                                    <span class="text-success ms-2">Saved successfully!</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(machine.Id)">Delete</button>
                        </div>
                    }
                </div>
            </div>
        }
        break;

    default:
        <div class="alert alert-warning">Unknown configuration type: @Entity</div>
        break;
}

<ConfirmDialog IsVisible="_showDeleteConfirm" Title="@($"Delete {_displayName}")"
               Message="@($"Are you sure you want to delete this {_displayName.ToLower()} record?")"
               ConfirmText="Delete" OnConfirm="ExecuteDelete" OnCancel="CancelDelete" />
