@page "/users"

<PageTitle>Users - HI Control Panel</PageTitle>

<div class="page-header">
    <h1>Users</h1>
    <button class="btn btn-primary" @onclick="ShowCreateModal">Create User</button>
</div>

<RadzenDataGrid Data="@_users" TItem="UserRecord" AllowSorting="true" AllowFiltering="true"
                FilterMode="FilterMode.Simple" PageSize="25" AllowPaging="true"
                RowClick="@(args => Navigation.NavigateTo($"/users/{args.Data.Id}"))"
                Style="cursor: pointer;">
    <Columns>
        <RadzenDataGridColumn TItem="UserRecord" Property="Id" Title="ID" Width="80px" />
        <RadzenDataGridColumn TItem="UserRecord" Property="Username" Title="Username" />
        <RadzenDataGridColumn TItem="UserRecord" Title="Scopes" Sortable="false" Filterable="false">
            <Template Context="user">
                @foreach (var scope in user.Scopes)
                {
                    <span class="badge bg-info text-dark me-1 scope-badge">@scope</span>
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="UserRecord" Title="Status" Width="120px" Sortable="false" Filterable="false">
            <Template Context="user">
                @if (user.IsDeleted)
                {
                    <StatusBadge Text="Deleted" Type="deleted" />
                }
                else
                {
                    <StatusBadge Text="Active" Type="active" />
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="UserRecord" Title="Actions" Width="160px" Sortable="false" Filterable="false">
            <Template Context="user">
                @if (!user.IsDeleted)
                {
                    <button class="btn btn-sm btn-outline-light me-1" @onclick="() => NavigateToEdit(user.Id)" @onclick:stopPropagation="true" title="Edit">
                        &#9998;
                    </button>
                    <button class="btn btn-sm btn-outline-light me-1" @onclick="() => NavigateToLogs(user.Id)" @onclick:stopPropagation="true" title="Logs">
                        &#128203;
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(user)" @onclick:stopPropagation="true" title="Delete">
                        &#128465;
                    </button>
                }
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

<!-- Create User Modal -->
@if (_showCreateModal)
{
    <div class="modal fade show d-block modal-overlay" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create User</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" @bind="_newUsername" placeholder="Enter username" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" @bind="_newPassword" placeholder="Enter password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Scopes</label>
                        @foreach (var scope in _availableScopes)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@_selectedScopes.Contains(scope)"
                                       @onchange="(e) => ToggleScope(scope, (bool)e.Value!)" />
                                <label class="form-check-label">@scope</label>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_createError))
                    {
                        <div class="alert alert-danger py-2">@_createError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light btn-sm" @onclick="CloseCreateModal">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="CreateUser">Create</button>
                </div>
            </div>
        </div>
    </div>
}

<ConfirmDialog IsVisible="_showDeleteConfirm" Title="Delete User"
               Message="@($"Are you sure you want to delete user '{_userToDelete?.Username}'?")"
               ConfirmText="Delete" OnConfirm="DeleteUser" OnCancel="CancelDelete" />
