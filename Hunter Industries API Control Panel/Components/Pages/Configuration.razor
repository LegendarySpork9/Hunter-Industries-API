@page "/configuration"

<PageTitle>Configuration - HI Control Panel</PageTitle>

<h4 class="mb-4">Configuration</h4>

<div class="row g-4">
    @foreach (var configType in _configTypes)
    {
        <div class="col-md-4 col-xl-3">
            <a href="/configuration/@configType.Key" class="text-decoration-none">
                <div class="card h-100" style="border-radius: 8px; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;"
                     onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.3)';"
                     onmouseout="this.style.transform='none'; this.style.boxShadow='none';">
                    <div class="card-body text-center py-4">
                        <div class="mb-3" style="font-size: 2.5rem; color: #7ec8e3;">
                            @((MarkupString)configType.Value.Icon)
                        </div>
                        <h5 class="card-title mb-0" style="color: #D7D7D7;">@configType.Value.DisplayName</h5>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
