@{
    var cardStyle = "background-color: " + (IsError && int.TryParse(Value, out var v) && v > 10 ? "#dc3545" : "#3E3E3E") + ";";
    var iconStyle = "color: " + IconColour + ";";
}

<div class="card h-100" style="@cardStyle border-color: #555; border-radius: 8px;">
    <div class="card-body d-flex flex-column justify-content-between p-3">
        <div class="d-flex justify-content-between align-items-start">
            <span class="text-muted" style="font-size: 0.85rem;">@Title</span>
            <span style="@iconStyle font-size: 1.25rem;">@((MarkupString)Icon)</span>
        </div>
        <div>
            <h2 class="mb-0 mt-2" style="font-size: 2rem; font-weight: 700; color: #fff;">@Value</h2>
            @if (!string.IsNullOrEmpty(Trend))
            {
                @if (IsError)
                {
                    <small class="@(Trend.StartsWith("-") ? "text-success" : Trend.StartsWith("+") ? "text-danger" : "text-muted")" style="font-size: 0.75rem;">
                        @Trend vs last month
                    </small>
                }
                else
                {
                    <small class="@(Trend.StartsWith("+") ? "text-success" : Trend.StartsWith("-") ? "text-danger" : "text-muted")" style="font-size: 0.75rem;">
                        @Trend vs last month
                    </small>
                }
            }
        </div>
    </div>
</div>
